{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Edit",
      "Write",
      "Bash"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(nmap*)",
      "Bash(nuclei*)",
      "Bash(subfinder*)",
      "Bash(httpx*)",
      "Bash(ffuf*)",
      "Bash(feroxbuster*)",
      "Bash(masscan*)",
      "Bash(amass*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  }
}
