{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "dontAsk",
    "deny": [
      "Bash(sudo*)",
      "Bash(rm -rf*)",
      "Bash(nmap*)",
      "Bash(nuclei*)",
      "Bash(subfinder*)",
      "Bash(httpx*)",
      "Bash(ffuf*)",
      "Bash(feroxbuster*)",
      "Bash(masscan*)",
      "Bash(amass*)",
      "Bash(naabu*)",
      "Bash(assetfinder*)",
      "Bash(dnsx*)",
      "Bash(katana*)",
      "Bash(gau*)",
      "Bash(waybackurls*)",
      "Bash(gowitness*)",
      "Bash(trufflehog*)",
      "Bash(gitleaks*)",
      "Bash(arjun*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.keystore)",
      "Read(./**/*id_rsa*)",
      "Read(./**/*id_ed25519*)"
    ]
  }
}
